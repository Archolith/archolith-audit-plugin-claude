{
  "name": "archolith-audit",
  "version": "0.1.0",
  "description": "Live MCP token usage audit. Tracks per-server token spend and waste patterns in real time.",
  "author": "archolith",
  "homepage": "https://archolith.dev",
  "components": {
    "hooks": true,
    "skills": ["audit"],
    "mcpServers": ["archolith-audit"]
  },
  "mcpServers": {
    "archolith-audit": {
      "command": "python",
      "args": ["-m", "archolith_mcp_audit.mcp_server"],
      "env": {
        "MCP_AUDIT_ENABLED": "1",
        "MCP_AUDIT_SESSION_ID": "${CLAUDE_SESSION_ID}",
        "PYTHONPATH": "${CLAUDE_PLUGIN_DIR}"
      }
    }
  }
}
